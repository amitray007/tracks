    "test": "vitest run"
  },
  "dependencies": {
    "@tracks/live-protocol": "workspace:*",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "vitest": "4.1.10"
  }
}
