{
  "name": "tracks",
  "version": "0.0.0",
  "description": "Local-first viewer and sharing tool for AI coding-agent sessions",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitray007/tracks.git"
  },
  "homepage": "https://github.com/amitray007/tracks#readme",
  "bugs": {
    "url": "https://github.com/amitray007/tracks/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "local-first",
    "session-viewer",
    "tracing"
  ],
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "portless",
    "dev:plain": "concurrently --kill-others-on-fail --names api,web \"pnpm --filter @tracks/server dev\" \"pnpm --filter @tracks/web dev\"",
    "build": "pnpm -r --if-present --sort build",
    "typecheck": "pnpm build:packages && pnpm --filter @tracks/server build && pnpm -r --if-present --sort typecheck",
    "test": "pnpm build:packages && pnpm -r --if-present --sort test",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "build:packages": "pnpm --filter './packages/**' --sort build",
    "cloud:dev": "pnpm --filter @tracks/cloud dev",
    "cloud:start": "pnpm --filter @tracks/cloud start",
    "tracks": "pnpm --filter @tracks/cli dev"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "concurrently": "10.0.3",
    "portless": "0.15.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
