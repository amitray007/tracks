# Generate two different values with: openssl rand -hex 32
TRACKS_OWNER_TOKEN=replace-with-a-random-owner-token-of-at-least-32-characters
TRACKS_DEVICE_TOKEN=replace-with-a-different-random-device-token-of-at-least-32-characters

# Keep the bootstrap deployment loopback-only. Put it behind TLS before exposing it.
TRACKS_CLOUD_BIND=127.0.0.1
TRACKS_CLOUD_PORT=8787

# Set this when a TLS reverse proxy exposes Tracks publicly. It enables Secure owner-session cookies.
TRACKS_CLOUD_PUBLIC_URL=
